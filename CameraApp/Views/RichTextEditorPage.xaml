<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="CameraApp.Views.RichTextEditorPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CameraApp.ViewModels"
             x:DataType="viewmodels:RichTextEditorViewModel"
             Title="{Binding PageTitle}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"/>
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16">

        <!-- Header -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource Primary}"
                Padding="16"
                StrokeShape="RoundRectangle 10"
                Margin="0,0,0,12">
            <Label Text="{Binding PageTitle}"
                   FontSize="20"
                   FontAttributes="Bold"
                   TextColor="{StaticResource White}"
                   HorizontalOptions="Center"
                   SemanticProperties.HeadingLevel="Level1"/>
        </Border>

        <!-- Campo Título -->
        <Border Grid.Row="1"
                BackgroundColor="{StaticResource White}"
                StrokeShape="RoundRectangle 8"
                Padding="0"
                Margin="0,0,0,12"
                Stroke="{StaticResource Gray200}">
            <Entry Text="{Binding Title}"
                   Placeholder="Título do conteúdo..."
                   PlaceholderColor="{StaticResource Gray400}"
                   TextColor="{StaticResource Black}"
                   FontSize="15"
                   Margin="12,0"
                   AutomationId="TitleEntry"/>
        </Border>

        <!-- Editor WebView -->
        <Border Grid.Row="2"
                BackgroundColor="{StaticResource White}"
                StrokeShape="RoundRectangle 10"
                Stroke="{StaticResource Gray200}"
                Padding="0"
                Margin="0,0,0,12">
            <WebView x:Name="QuillWebView"
                     AutomationId="QuillEditor"
                     BackgroundColor="{StaticResource White}"/>
        </Border>

        <!-- Botões de Ação -->
        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="10">

            <Label Grid.Column="0"
                   Text="Pronto"
                   TextColor="{StaticResource Gray400}"
                   FontSize="12"
                   VerticalOptions="Center"
                   IsVisible="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"/>

            <ActivityIndicator Grid.Column="0"
                               IsRunning="{Binding IsSaving}"
                               IsVisible="{Binding IsSaving}"
                               Color="{StaticResource Primary}"
                               HorizontalOptions="Start"
                               VerticalOptions="Center"/>

            <Button Grid.Column="1"
                    Text="Limpar"
                    Command="{Binding ClearCommand}"
                    BackgroundColor="{StaticResource Danger}"
                    TextColor="{StaticResource White}"
                    FontSize="14"
                    CornerRadius="8"
                    Padding="16,10"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                    AutomationId="ClearButton"/>

            <Button Grid.Column="2"
                    Text="Salvar"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="{StaticResource Success}"
                    TextColor="{StaticResource White}"
                    FontSize="14"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="16,10"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InvertedBoolConverter}}"
                    AutomationId="SaveButton"/>
        </Grid>

    </Grid>
</ContentPage>
